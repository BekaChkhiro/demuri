tatus: 400 });\n50\t\t});\n51\t\n52\t\tit('returns 400 when the file is empty (0 bytes)', async () => {\n53\t\t\tconst file = new File([], 'empty.jpg', { type: 'image/jpeg' });\n54\t\t\tawait expect(\n55\t\t\t\tPOST({ request: makeRequest({ photo: file }), platform: makePlatform() } as never)\n56\t\t\t).rejects.toMatchObject({ status: 400 });\n57\t\t});\n58\t\n59\t\tit('returns 400 when the file exceeds the 8 MB limit', async () => {\n60\t\t\tconst file = new File([new Uint8Array(9 * 1024 * 1024)], 'big.jpg', { type: 'image/jpeg' });\n61\t\t\tawait expect(\n62\t\t\t\tPOST({ request: makeRequest({ photo: file }), platform: makePlatform() } as never)\n63\t\t\t).rejects.toMatchObject({ status: 400 });\n64\t\t});\n65\t\n66\t\tit('returns 201 with a well-formed PhotoResponse on a valid upload', async () => {\n67\t\t\tconst platform = makePlatform();\n68\t\t\tconst response = await POST({\n69\t\t\t\trequest: makeRequest({ photo: makeImageFile(), name: 'Beach Sunset' }),\n70\t\t\t\tplatform\n71\t\t\t} as never);\n72\t\n73\t\t\texpect(response.status).toBe(201);\n74\t\t\tconst body = await response.json();\n75\t\t\texpect(body).toMatchObject({\n76\t\t\t\tid: expect.any(String),\n77\t\t\t\turl: expect.stringContaining('https://cdn.example.com/photos/'),\n78\t\t\t\tname: 'Beach Sunset',\n79\t\t\t\tcreatedAt: expect.any(Number)\n80\t\t\t});\n81\t\t});\n82\t\n83\t\tit('returns null name when the name field is omitted', async () => {\n84\t\t\tconst platform = makePlatform();\n85\t\t\tconst response = await POST({\n86\t\t\t\trequest: makeRequest({ photo: makeImageFile() }),\n87\t\t\t\tplatform\n88\t\t\t} as never);\n89\t\t\tconst body = await response.json();\n90\t\t\texpect(body.name).toBeNull();\n91\t\t});\n92\t\n93\t\tit('sanitizes the name field before returning', async () => {\n94\t\t\tconst platform = makePlatform();\n95\t\t\tconst response = await POST({\n96\t\t\t\trequest: makeRequest({ photo: makeImageFile(), name: '  Trimmed  ' }),\n97\t\t\t\tplatform\n98\t\t\t} as never);\n99\t\t\tconst body = await response.json();\n100\t\t\texpect(body.name).toBe('Trimmed');\n101\t\t});\n102\t\n103\t\tit('calls R2 bucket.put once with a key under the photos/ prefix', async () => {\n104\t\t\tconst platform = makePlatform();\n105\t\t\tawait POST({ request: makeRequest({ photo: makeImageFile() }), platform } as never);\n106\t\t\texpect(platform.env!.PHOTOS_BUCKET.put).toHaveBeenCalledOnce();\n107\t\t\tconst [key] = (platform.env!.PHOTOS_BUCKET.put as ReturnType<typeof vi.fn>).mock.calls[0];\n108\t\t\texpect(key).toMatch(/^photos\\//);\n109\t\t});\n110\t\n111\t\tit('accepts image/png in addition to image/jpeg', async () => {\n112\t\t\tconst platform = makePlatform();\n113\t\t\tconst png = new File([new Uint8Array(512)], 'test.png', { type: 'image/png' });\n114\t\t\tconst response = await POST({ request: makeRequest({ photo: png }), platform } as never);\n115\t\t\texpect(response.status).toBe(201);\n116\t\t});\n117\t});\n118\t"}]},"parent_tool_use_id":null,"session_id":"bd332b78-21a3-4ac0-a7b2-54765625a514","uuid":"4b55c5e3-ae31-4497-9e26-f95074a43362","timestamp":"2026-05-26T15:30:34.944Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/routes/api/upload/server.test.ts","content":"import { describe, it, expect, vi } from 'vitest';\nimport { POST } from './+server';\n\nfunction makePlatform() {\n\tconst run = vi.fn().mockResolvedValue({ success: true });\n\tconst boundStmt = { run };\n\tconst bind = vi.fn().mockReturnValue(boundStmt);\n\tconst stmt = { bind };\n\tconst prepare = vi.fn().mockReturnValue(stmt);\n\tconst db = { prepare };\n\n\tconst bucket = { put: vi.fn().mockResolvedValue(undefined) };\n\n\treturn {\n\t\tenv: {\n\t\t\tDB: db,\n\t\t\tPHOTOS_BUCKET: bucket,\n\t\t\tR2_PUBLIC_BASE_URL: 'https://cdn.example.com'\n\t\t}\n\t} as unknown as App.Platform;\n}\n\nfunction makeImageFile(sizeBytes = 1024, type = 'image/jpeg') {\n\treturn new File([new Uint8Array(sizeBytes)], 'test.jpg', { type });\n}\n\nfun