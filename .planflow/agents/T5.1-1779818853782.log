dleCapture} />\n\t</section>\n\n\t{#if previewUrl}\n\t\t<section class=\"preview-section\">\n\t\t\t<h2>Last capture</h2>\n\t\t\t<img src={previewUrl} alt=\"Last capture preview\" class=\"preview-img\" />\n\t\t\t{#if name}\n\t\t\t\t<p class=\"preview-name\">by {name}</p>\n\t\t\t{/if}\n\t\t</section>\n\t{/if}\n\n\t<section class=\"gallery-section\">\n\t\t<h2>Live wall</h2>\n\t\t<Gallery store={gallery} />\n\t</section>\n</main>\n\n<style>\n\t:global(body) {\n\t\tmargin: 0;\n\t\tbackground: #0a0a0a;\n\t\tcolor: #e0e0e0;\n\t\tfont-family:\n\t\t\tsystem-ui,\n\t\t\t-apple-system,\n\t\t\tsans-serif;\n\t\tmin-height: 100dvh;\n\t}\n\n\tmain {\n\t\tmax-width: 520px;\n\t\tmargin: 0 auto;\n\t\tpadding: 1.5rem 1rem 3rem;\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t\tgap: 1.5rem;\n\t}\n\n\theader {\n\t\ttext-align: center;\n\t}\n\n\th1 {\n\t\tmargin: 0 0 0.25rem;\n\t\tfont-size: 2rem;\n\t\tfont-weight: 800;\n\t\tcolor: #39ff14;\n\t\tletter-spacing: -0.02em;\n\t}\n\n\t.subtitle {\n\t\tmargin: 0;\n\t\tcolor: #666;\n\t\tfont-size: 0.9rem;\n\t}\n\n━━━ #4 ━━━━━━━━━━━━━━━━━━━━━━━━━━\nfile:      src/lib/components/Gallery.svelte\nlines:     1-79\nkind:      module\nname:      Gallery.svelte\nlanguage:  svelte\nmatch:     hybrid\nscore:     1.053\nchunkId:   src/lib/components/Gallery.svelte:1\n\ncontent:\n<script lang=\"ts\">\n\timport { scale } from 'svelte/transition';\n\timport { cubicOut } from 'svelte/easing';\n\timport type { GalleryStore } from '$lib/gallery';\n\n\tlet { store }: { store: GalleryStore } = $props();\n</script>\n\n<section class=\"gallery\" aria-live=\"polite\">\n\t{#if $store.photos.length > 0}\n\t\t<div class=\"masonry\">\n\t\t\t{#each $store.photos as photo (photo.id)}\n\t\t\t\t<figure\n\t\t\t\t\tclass=\"tile\"\n\t\t\t\t\tin:scale={{ duration: 400, start: 0.92, opacity: 0, easing: cubicOut }}\n\t\t\t\t>\n\t\t\t\t\t<img\n\t\t\t\t\t\tsrc={photo.url}\n\t\t\t\t\t\talt={photo.name ? `Photo shared by ${photo.name}` : 'Event photo'}\n\t\t\t\t\t\tloading=\"lazy\"\n\t\t\t\t\t\tdecoding=\"async\"\n\t\t\t\t\t/>\n\t\t\t\t\t{#if photo.name}\n\t\t\t\t\t\t<figcaption>{photo.name}</figcaption>\n\t\t\t\t\t{/if}\n\t\t\t\t</figure>\n\t\t\t{/each}\n\t\t</div>\n\t{:else if $store.status === 'loading' || $store.status === 'idle'}\n\t\t<p class=\"placeholder\">Loading the wall…</p>\n\t{:else if $store.status === 'error'}\n\t\t<p class=\"placeholder error\">Couldn't load the gallery. New photos will still appear live.</p>\n\t{:else}\n\t\t<p class=\"placeholder\">No photos yet — be the first to share one!</p>\n\t{/if}\n</section>\n\n<style>\n\t.gallery {\n\t\twidth: 100%;\n\t}\n\n\t/* CSS-columns masonry: newest-first items prepend at the top-left and the\n\t   rest flow down without re-laying-out the whole grid. */\n\t.masonry {\n\t\tcolumn-count: 2;\n\t\tcolumn-gap: 0.75rem;\n\t}\n\n\t@media (min-width: 640px) {\n\t\t.masonry {\n\t\t\tcolumn-count: 3;\n\t\t}\n\t}\n\n\t.tile {\n\t\tbreak-inside: avoid;\n\t\tmargin: 0 0 0.75rem;\n\t\tborder-radius: 10px;\n\t\toverflow: hidden;\n\t\tbackground: #111;\n\t\tborder: 1px solid #1c1c1c;\n\t}\n\n\t.tile img {\n\t\twidth: 100%;\n\t\theight: auto;\n\t\tdisplay: block;\n\t}\n\n\tfigcaption {\n\t\tpadding: 0.4rem 0.6rem;\n\t\tfont-size: 0.8rem;\n\t\tcolor: #888;\n\t}\n\n\t.placeholder {\n\t\ttext-align: center;\n\t\tcolor: #555;\n\t\tfont-size: 0.9rem;\n\t\tpadding: 2rem 1rem;\n\t\tmargin: 0;\n\t}\n\n\t.placeholder.error {\n\t\tcolor: #ff4d4d;\n\t}\n</style>\n\n━━━ #5 ━━━━━━━━━━━━━━━━━━━━━━━━━━\nfile:      src/routes/+layout.svelte\nlines:     1-5\nkind:      module\nname:      +layout.svelte\nlanguage:  svelte\nmatch:     hybrid\nscore:     1.030\nchunkId:   src/routes/+layout.svelte:1\n\ncontent:\n<script lang=\"ts\">\n\tlet { children } = $props();\n</script>\n\n{@render children()}\n\n━━━ #6 ━━━━━━━━━━━━━━━━━━━━━━━━━━\nfile:      src/app.d.ts\nlines:     1-29\nkind:      module\nname:      module\nlanguage:  typescript\nmatch:     hybrid\nscore:     1.025\nchunkId:   9987a0c15328dc61\n\ncontent:\