{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hk9JLeeJ3qok3nZKMgLNK3","type":"tool_result","content":"1\timport { describe, it, expect, vi } from 'vitest';\n2\timport { broadcastToGallery } from './gallery';\n3\timport { BROADCAST_PATH } from './GalleryRoom';\n4\timport { GALLERY_ROOM_NAME } from './gallery-room-name';\n5\t\n6\tfunction makeGallery() {\n7\t\tconst id = { toString: () => 'gallery-id' };\n8\t\tconst stub = { fetch: vi.fn().mockResolvedValue(new Response(null)) };\n9\t\tconst idFromName = vi.fn().mockReturnValue(id);\n10\t\tconst get = vi.fn().mockReturnValue(stub);\n11\t\treturn { gallery: { idFromName, get }, idFromName, get, stub, id };\n12\t}\n13\t\n14\tdescribe('broadcastToGallery', () => {\n15\t\tit('resolves the single room DO and POSTs the serialized message to /broadcast', async () => {\n16\t\t\tconst { gallery, idFromName, get, stub, id } = makeGallery();\n17\t\t\tconst message = { type: 'photo:new', photo: { id: 'abc', url: 'https://x/y.jpg' } };\n18\t\n19\t\t\tawait broadcastToGallery(gallery as never, message);\n20\t\n21\t\t\texpect(idFromName).toHaveBeenCalledWith(GALLERY_ROOM_NAME);\n22\t\t\texpect(get).toHaveBeenCalledWith(id);\n23\t\n24\t\t\texpect(stub.fetch).toHaveBeenCalledOnce();\n25\t\t\tconst [url, init] = stub.fetch.mock.calls[0];\n26\t\t\texpect(String(url)).toContain(BROADCAST_PATH);\n27\t\t\texpect(init.method).toBe('POST');\n28\t\t\texpect(init.body).toBe(JSON.stringify(message));\n29\t\t});\n30\t});\n31\t"}]},"parent_tool_use_id":null,"session_id":"b993d51d-2ee5-4324-86da-92972366a562","uuid":"91a5dbf2-0fe0-42fe-908e-7e6e77b06075","timestamp":"2026-05-26T15:36:53.702Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/lib/server/gallery.test.ts","content":"import { describe, it, expect, vi } from 'vitest';\nimport { broadcastToGallery } from './gallery';\nimport { BROADCAST_PATH } from './GalleryRoom';\nimport { GALLERY_ROOM_NAME } from './gallery-room-name';\n\nfunction makeGallery() {\n\tconst id = { toString: () => 'gallery-id' };\n\tconst stub = { fetch: vi.fn().mockResolvedValue(new Response(null)) };\n\tconst idFromName = vi.fn().mockReturnValue(id);\n\tconst get = vi.fn().mockReturnValue(stub);\n\treturn { gallery: { idFromName, get }, idFromName, get, stub, id };\n}\n\ndescribe('broadcastToGallery', () => {\n\tit('resolves the single room DO and POSTs the serialized message to /broadcast', async () => {\n\t\tconst { gallery, idFromName, get, stub, id } = makeGallery();\n\t\tconst message = { type: 'photo:new', photo: { id: 'abc', url: 'https://x/y.jpg' } };\n\n\t\tawait broadcastToGallery(gallery as never, message);\n\n\t\texpect(idFromName).toHaveBeenCalledWith(GALLERY_ROOM_NAME);\n\t\texpect(get).toHaveBeenCalledWith(id);\n\n\t\texpect(stub.fetch).toHaveBeenCalledOnce();\n\t\tconst [url, init] = stub.fetch.mock.calls[0];\n\t\texpect(String(url)).toContain(BROADCAST_PATH);\n\t\texpect(init.method).toBe('POST');\n\t\texpect(init.body).toBe(JSON.stringify(message));\n\t});\n});\n","numLines":31,"startLine":1,"totalLines":31}}}
