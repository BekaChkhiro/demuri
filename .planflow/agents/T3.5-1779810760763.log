{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014AjqcE6SypWLSjrr8t2VgC","type":"tool_result","content":"1\timport { describe, it, expect, vi } from 'vitest';\n2\timport {\n3\t\tsanitizeName,\n4\t\tpublicUrl,\n5\t\ttoPhotoResponse,\n6\t\tinsertPhoto,\n7\t\tlistPhotos,\n8\t\tMAX_NAME_LENGTH,\n9\t\tMAX_LIMIT,\n10\t\tDEFAULT_LIMIT\n11\t} from './photos';\n12\timport type { Photo } from './db';\n13\timport type { D1Database } from '@cloudflare/workers-types';\n14\t\n15\tfunction makeD1(rows: Photo[] = []) {\n16\t\tconst all = vi.fn().mockResolvedValue({ results: rows });\n17\t\tconst run = vi.fn().mockResolvedValue({ success: true });\n18\t\tconst boundStmt = { all, run };\n19\t\tconst bind = vi.fn().mockReturnValue(boundStmt);\n20\t\tconst stmt = { bind };\n21\t\tconst prepare = vi.fn().mockReturnValue(stmt);\n22\t\tconst db = { prepare } as unknown as D1Database;\n23\t\treturn { db, stmt, all, run };\n24\t}\n25\t\n26\tfunction makePhotoRow(n: number): Photo {\n27\t\treturn {\n28\t\t\tid: `id-${n}`,\n29\t\t\tr2_key: `photos/id-${n}.jpg`,\n30\t\t\tname: `Photo ${n}`,\n31\t\t\tcreated_at: 1_700_000_000_000 - n * 1000,\n32\t\t\thidden: 0\n33\t\t};\n34\t}\n35\t\n36\tconst BASE = 'https://cdn.example.com';\n37\t\n38\tdescribe('sanitizeName', () => {\n39\t\tit('returns null for null input', () => {\n40\t\t\texpect(sanitizeName(null)).toBeNull();\n41\t\t});\n42\t\n43\t\tit('returns null for a File (non-string FormDataEntryValue)', () => {\n44\t\t\tconst file = new File([''], 'test.jpg', { type: 'image/jpeg' });\n45\t\t\texpect(sanitizeName(file)).toBeNull();\n46\t\t});\n47\t\n48\t\tit('returns null for empty string', () => {\n49\t\t\texpect(sanitizeName('')).toBeNull();\n50\t\t});\n51\t\n52\t\tit('returns null for whitespace-only string', () => {\n53\t\t\texpect(sanitizeName('   ')).toBeNull();\n54\t\t});\n55\t\n56\t\tit('strips ASCII control characters', () => {\n57\t\t\texpect(sanitizeName('hello\\x00world')).toBe('helloworld');\n58\t\t\texpect(sanitizeName('foo\\x1fbar')).toBe('foobar');\n59\t\t\texpect(sanitizeName('tab\\ttab')).toBe('tabtab');\n60\t\t});\n61\t\n62\t\tit('strips DEL (0x7f)', () => {\n63\t\t\texpect(sanitizeName('del\\x7fchar')).toBe('delchar');\n64\t\t});\n65\t\n66\t\tit('trims surrounding whitespace', () => {\n67\t\t\texpect(sanitizeName('  hello  ')).toBe('hello');\n68\t\t});\n69\t\n70\t\tit('truncates to MAX_NAME_LENGTH', () => {\n71\t\t\tconst long = 'a'.repeat(MAX_NAME_LENGTH + 10);\n72\t\t\texpect(sanitizeName(long)).toHaveLength(MAX_NAME_LENGTH);\n73\t\t});\n74\t\n75\t\tit('returns the original value for a short valid name', () => {\n76\t\t\texpect(sanitizeName('Alice')).toBe('Alice');\n77\t\t});\n78\t\n79\t\tit('preserves non-ASCII characters', () => {\n80\t\t\texpect(sanitizeName('Güz')).toBe('Güz');\n81\t\t});\n82\t});\n83\t\n84\tdescribe('publicUrl', () => {\n85\t\tit('concatenates base and key with a slash', () => {\n86\t\t\texpect(publicUrl('https://cdn.example.com', 'photos/abc.jpg')).toBe(\n87\t\t\t\t'https://cdn.example.com/photos/abc.jpg'\n88\t\t\t);\n89\t\t});\n90\t\n91\t\tit('strips a single trailing slash from base', () => {\n92\t\t\texpect(publicUrl('https://cdn.example.com/', 'photos/abc.jpg')).toBe(\n93\t\t\t\t'https://cdn.example.com/photos/abc.jpg'\n94\t\t\t);\n95\t\t});\n96\t\n97\t\tit('strips multiple trailing slashes from base', () => {\n98\t\t\texpect(publicUrl('https://cdn.example.com///', 'photos/abc.jpg')).toBe(\n99\t\t\t\t'https://cdn.example.com/photos/abc.jpg'\n100\t\t\t);\n101\t\t});\n102\t});\n103\t\n104\tdescribe('toPhotoResponse', () => {\n105\t\tit('maps a Photo row to the correct PhotoResponse shape', () => {\n106\t\t\tconst photo: Photo = {\n107\t\t\t\tid: 'uuid-1',\n108\t\t\t\tr2_key: 'photos/uuid-1.jpg',\n109\t\t\t\tname: 'Sunset',\n110\t\t\t\tcreated_at: 1_700_000_000_000,\n111\t\t\t\thidden: 0\n112\t\t\t};\n113\t\t\texpect(toPhotoResponse(photo, BASE)).toEqual({\n114\t\t\t\tid: 'uuid-1',\n115\t\t\t\turl: `${BASE}/photos/uuid-1.jpg`,\n116\t\t\t\tname: 'Sunset',\n117\t\t\t\tcreatedAt: 1_700_000_000_000\n118\t\t\t});\n119\t\t});\n120\t\n121\t\tit('propagates null name', () => {\n122\t\t\tconst photo: Photo = {\n123\t\t\t\tid: 'uuid-2',\n124\t\t\t\tr2_key: 'photos/uuid-2.jpg',\n125\t\t\t\tname: null,\n126\t\t\t\tcreated_at: 1_700_000_000_001,\n127\t\t\t\thidden: 0\n128\t\t\t};\n129\t\t\texpect(toPhotoResponse(photo, BASE).name).toBeNull();\n130\t\t});\n131\t});\n132\t\n133\tdescribe('insertPhoto', () => {\n134\t\tit('executes an INSERT with the correct bound values', async () => {\n135\t\t\tconst { db, stmt, run } = makeD1();\n136\t\t\tawait insertPhoto(db, { id: 'abc', r2_key: 'photos/abc.jpg', name: 'Test', created_at: 123 });\n137\t\t\texpect(stmt.bind).toHaveBeenCalledWith('abc', 'photos/abc.jpg', 'Test', 123);\n138\t\t\texpect(run).toHaveBeenCalled();\n139\t\t});\n140\t\n141\t\tit('accepts null name', async () => {\n142\t\t\tconst { db, stmt } = makeD1();\n143\t\t\tawait insertPhoto(db, { id: 'xyz', r2_key: 'photos/xyz.jpg', name: null, created_at: 1 });\n144\t\t\texpect(stmt.bind).toHaveBeenCalledWith('xyz', 'photos/xyz.jpg', null, 1);\n145\t\t});\n146\t});\n147\t\n148\tdescribe('listPhotos', () => {\n149\t\tit('returns an empty list when there are no rows', async () => {\n150\t\t\tconst { db } = makeD1([]);\n151\t\t\tconst result = await listPhotos(db, BASE, null, DEFAULT_LIMIT);\n152\t\t\texpect(result.photos).toHaveLength(0);\n153\t\t\texpect(result.nextBefore).toBeNull();\n154\t\t});\n155\t\n156\t\tit('returns all rows and null nextBefore when result count is below limit', async () => {\n157\t\t\tconst rows = [makePhotoRow(1), makePhotoRow(2)];\n158\t\t\tconst { db } = makeD1(rows);\n159\t\t\tconst result = await listPhotos(db, BASE, null, 5);\n160\t\t\texpect(result.photos).toHaveLength(2);\n161\t\t\texpect(result.nextBefore).toBeNull();\n162\t\t});\n163\t\n164\t\tit('sets nextBefore when the DB returns more rows than the requested limit', async () => {\n165\t\t\t// listPhotos fetches limit+1 internally to detect a next page\n166\t\t\tconst rows = [makePhotoRow(1), makePhotoRow(2), makePhotoRow(3)];\n167\t\t\tconst { db } = makeD1(rows);\n168\t\t\tconst result = await listPhotos(db, BASE, null, 2);\n169\t\t\texpect(result.photos).toHaveLength(2);\n170\t\t\texpect(result.nextBefore).toBe(rows[2].created_at);\n171\t\t});\n172\t\n173\t\tit('clamps limit to MAX_LIMIT', async () => {\n174\t\t\tconst rows = Array.from({ length: MAX_LIMIT + 1 }, (_, i) => makePhotoRow(i));\n175\t\t\tconst { db } = makeD1(rows);\n176\t\t\tconst result = await listPhotos(db, BASE, null, MAX_LIMIT + 100);\n177\t\t\texpect(result.photos).toHaveLength(MAX_LIMIT);\n178\t\t\texpect(result.nextBefore).not.toBeNull();\n179\t\t});\n180\t\n181\t\tit('passes the before cursor to bind() when provided', async () => {\n182\t\t\tconst { db, stmt } = makeD1([]);\n183\t\t\tconst cursor = 1_700_000_000_000;\n184\t\t\tawait listPhotos(db, BASE, cursor, DEFAULT_LIMIT);\n185\t\t\texpect(stmt.bind).toHaveBeenCalledWith(cursor, expect.any(Number));\n186\t\t});\n187\t\n188\t\tit('does not pass before to bind() when cursor is null', async () => {\n189\t\t\tconst { db, stmt } = makeD1([]);\n190\t\t\tawait listPhotos(db, BASE, null, DEFAULT_LIMIT);\n191\t\t\t// Without cursor, only fetchLimit is bound\n192\t\t\texpect(stmt.bind).toHaveBeenCalledWith(expect.any(Number));\n193\t\t\texpect(stmt.bind).not.toHaveBeenCalledWith(expect.any(Number), expect.any(Number));\n194\t\t});\n195\t\n196\t\tit('maps rows to the correct public URL', async () => {\n197\t\t\tconst rows = [makePhotoRow(1)];\n198\t\t\tconst { db } = makeD1(rows);\n199\t\t\tconst result = await listPhotos(db, BASE, null, DEFAULT_LIMIT);\n200\t\t\texpect(result.photos[0].url).toBe(`${BASE}/${rows[0].r2_key}`);\n201\t\t});\n202\t});\n203\t"}]},"parent_tool_use_id":null,"session_id":"55beee22-13df-4723-9d47-0d074ee65835","uuid":"6208407b-e864-40da-9039-6d6ae2213c73","timestamp":"2026-05-26T15:54:03.452Z","tool_use_result":{"type":"text","file":{"filePath"