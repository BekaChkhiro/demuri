est({}), platform: makePlatform().platform } as never)\n52\t\t\t).rejects.toMatchObject({ status: 400 });\n53\t\t});\n54\t\n55\t\tit('returns 400 when the uploaded file is not an image', async () => {\n56\t\t\tconst file = new File(['hello'], 'document.pdf', { type: 'application/pdf' });\n57\t\t\tawait expect(\n58\t\t\t\tPOST({ request: makeRequest({ photo: file }), platform: makePlatform().platform } as never)\n59\t\t\t).rejects.toMatchObject({ status: 400 });\n60\t\t});\n61\t\n62\t\tit('returns 400 when the file is empty (0 bytes)', async () => {\n63\t\t\tconst file = new File([], 'empty.jpg', { type: 'image/jpeg' });\n64\t\t\tawait expect(\n65\t\t\t\tPOST({ request: makeRequest({ photo: file }), platform: makePlatform().platform } as never)\n66\t\t\t).rejects.toMatchObject({ status: 400 });\n67\t\t});\n68\t\n69\t\tit('returns 400 when the file exceeds the 8 MB limit', async () => {\n70\t\t\tconst file = new File([new Uint8Array(9 * 1024 * 1024)], 'big.jpg', { type: 'image/jpeg' });\n71\t\t\tawait expect(\n72\t\t\t\tPOST({ request: makeRequest({ photo: file }), platform: makePlatform().platform } as never)\n73\t\t\t).rejects.toMatchObject({ status: 400 });\n74\t\t});\n75\t\n76\t\tit('returns 201 with a well-formed PhotoResponse on a valid upload', async () => {\n77\t\t\tconst { platform } = makePlatform();\n78\t\t\tconst response = await POST({\n79\t\t\t\trequest: makeRequest({ photo: makeImageFile(), name: 'Beach Sunset' }),\n80\t\t\t\tplatform\n81\t\t\t} as never);\n82\t\n83\t\t\texpect(response.status).toBe(201);\n84\t\t\tconst body = await response.json();\n85\t\t\texpect(body).toMatchObject({\n86\t\t\t\tid: expect.any(String),\n87\t\t\t\turl: expect.stringContaining('https://cdn.example.com/photos/'),\n88\t\t\t\tname: 'Beach Sunset',\n89\t\t\t\tcreatedAt: expect.any(Number)\n90\t\t\t});\n91\t\t});\n92\t\n93\t\tit('returns null name when the name field is omitted', async () => {\n94\t\t\tconst { platform } = makePlatform();\n95\t\t\tconst response = await POST({\n96\t\t\t\trequest: makeRequest({ photo: makeImageFile() }),\n97\t\t\t\tplatform\n98\t\t\t} as never);\n99\t\t\tconst body = await response.json();\n100\t\t\texpect(body.name).toBeNull();\n101\t\t});\n102\t\n103\t\tit('sanitizes the name field before returning', async () => {\n104\t\t\tconst { platform } = makePlatform();\n105\t\t\tconst response = await POST({\n106\t\t\t\trequest: makeRequest({ photo: makeImageFile(), name: '  Trimmed  ' }),\n107\t\t\t\tplatform\n108\t\t\t} as never);\n109\t\t\tconst body = await response.json();\n110\t\t\texpect(body.name).toBe('Trimmed');\n111\t\t});\n112\t\n113\t\tit('calls R2 bucket.put once with a key under the photos/ prefix', async () => {\n114\t\t\tconst { platform } = makePlatform();\n115\t\t\tawait POST({ request: makeRequest({ photo: makeImageFile() }), platform } as never);\n116\t\t\texpect(platform.env!.PHOTOS_BUCKET.put).toHaveBeenCalledOnce();\n117\t\t\tconst [key] = (platform.env!.PHOTOS_BUCKET.put as ReturnType<typeof vi.fn>).mock.calls[0];\n118\t\t\texpect(key).toMatch(/^photos\\//);\n119\t\t});\n120\t\n121\t\tit('accepts image/png in addition to image/jpeg', async () => {\n122\t\t\tconst { platform } = makePlatform();\n123\t\t\tconst png = new File([new Uint8Array(512)], 'test.png', { type: 'image/png' });\n124\t\t\tconst response = await POST({ request: makeRequest({ photo: png }), platform } as never);\n125\t\t\texpect(response.status).toBe(201);\n126\t\t});\n127\t\n128\t\tit('broadcasts a photo:new message to the gallery DO after a successful upload', async () => {\n129\t\t\tconst { platform, doFetch, idFromName } = makePlatform();\n130\t\t\tconst response = await POST({\n131\t\t\t\trequest: makeRequest({ photo: makeImageFile(), name: 'Live Test' }),\n132\t\t\t\tplatform\n133\t\t\t} as never);\n134\t\n135\t\t\texpect(response.status).toBe(201);\n136\t\t\texpect(idFromName).toHaveBeenCalledWith('gallery');\n137\t\t\texpect(doFetch).toHaveBeenCalledOnce();\n138\t\n139\t\t\tconst [url, init] = (doFetch as ReturnType<typeof vi.fn>).mock.calls[0];\n140\t\t\texpect(url).toContain('/broadcast');\n141\t\t\texpect(init.method).toBe('POST');\n142\t\n143\t\t\tconst broadcastBody = JSON.parse(init.body);\n144\t\t\texpect(broadcastBody).toMatchObject({\n145\t\t\t\ttype: 'photo:new',\n146\t\t\t\tphoto: expect.objectContaining({\n147\t\t\t\t\tid: expect.any(String),\n148\t\t\t\t\turl: expect.stringContaining('https://cdn.example.com/photos/'),\n149\t\t\t\t\tname: 'Live Test',\n150\t\t\t\t\tcreatedAt: expect.any(Number)\n151\t\t\t\t})\n152\t\t\t});\n153\t\t});\n154\t\n155\t\tit('still returns 201 even when the gallery broadcast fails', async () => {\n156\t\t\tconst { platform, doFetch } = makePlatform();\n157\t\t\tdoFetch.mockRejectedValueOnce(new Error('DO unavailable'));\n158\t\n159\t\t\tconst response = await POST({\n160\t\t\t\trequest: makeRequest({ photo: makeImageFile() }),\n161\t\t\t\tplatform\n162\t\t\t} as never);\n163\t\n164\t\t\texpect(response.status).toBe(201);\n165\t\t});\n166\t});\n167\t"}]},"parent_tool_use_id":null,"session_id":"489aa259-b289-4b1c-b519-d0e8cbd7d59f","uuid":"880979b2-33ef-4546-b302-863844319d6f","timestamp":"2026-05-26T16:05:25.663Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/routes/api/upload/server.test.ts","content":"import { describe, it, expect, vi } from 'vitest';\nimport { POST } from './+server';\n\nfunction makePlatform() {\n\tconst run = vi.fn().mockResolvedValue({ success: true });\n\tconst boundStmt = { run };\n\tconst bind = vi.fn().mockReturnValue(boundStmt);\n\tconst stmt = { bind };\n\tconst prepare = vi.fn().mockReturnValue(stmt);\n\tconst db = { prepare };\n\n\tconst bucket = { put: vi.fn().mockResolvedValue(undefined) };\n\n\tconst doFetch = vi.fn().mockResolvedValue(new Response(JSON.stringify({ delivered: 0 })));\n\tconst doStub = { fetch: doFetch };\n\tconst doId = {};\n\tconst idFromName = vi.fn().mockReturnValue(doId);\n\tconst doGet = vi.fn().mockReturnValue(doStub);\n\tconst galler