ody = await response.json();\n53\t\t\texpect(body.photos[0].url).toContain('https://cdn.example.com/photos/');\n54\t\t});\n55\t\n56\t\tit('returns 400 for a non-numeric before param', async () => {\n57\t\t\tawait expect(GET(makeEvent({ before: 'abc' }))).rejects.toMatchObject({ status: 400 });\n58\t\t});\n59\t\n60\t\tit('returns 400 for before=0', async () => {\n61\t\t\tawait expect(GET(makeEvent({ before: '0' }))).rejects.toMatchObject({ status: 400 });\n62\t\t});\n63\t\n64\t\tit('returns 400 for a negative before param', async () => {\n65\t\t\tawait expect(GET(makeEvent({ before: '-100' }))).rejects.toMatchObject({ status: 400 });\n66\t\t});\n67\t\n68\t\tit('returns 400 for a non-integer limit (float)', async () => {\n69\t\t\tawait expect(GET(makeEvent({ limit: '5.5' }))).rejects.toMatchObject({ status: 400 });\n70\t\t});\n71\t\n72\t\tit('returns 400 for limit=0', async () => {\n73\t\t\tawait expect(GET(makeEvent({ limit: '0' }))).rejects.toMatchObject({ status: 400 });\n74\t\t});\n75\t\n76\t\tit('returns 400 for limit exceeding MAX_LIMIT', async () => {\n77\t\t\tawait expect(GET(makeEvent({ limit: String(MAX_LIMIT + 1) }))).rejects.toMatchObject({\n78\t\t\t\tstatus: 400\n79\t\t\t});\n80\t\t});\n81\t\n82\t\tit('accepts the maximum allowed limit without error', async () => {\n83\t\t\tconst response = await GET(makeEvent({ limit: String(MAX_LIMIT) }, []));\n84\t\t\texpect(response.status).toBe(200);\n85\t\t});\n86\t\n87\t\tit('accepts a valid before cursor without error', async () => {\n88\t\t\tconst response = await GET(makeEvent({ before: '1700000000000' }, []));\n89\t\t\texpect(response.status).toBe(200);\n90\t\t});\n91\t\n92\t\tit('passes a pagination cursor back when more photos exist', async () => {\n93\t\t\t// Request 2 photos; provide 3 rows so listPhotos detects a next page\n94\t\t\tconst rows = [makePhotoRow(1), makePhotoRow(2), makePhotoRow(3)];\n95\t\t\tconst response = await GET(makeEvent({ limit: '2' }, rows));\n96\t\t\tconst body = await response.json