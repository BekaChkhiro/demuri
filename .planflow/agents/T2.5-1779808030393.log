{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NH254T2UL2sfNe9gR2KZBu","type":"tool_result","content":"1\timport type { D1Database } from '@cloudflare/workers-types';\n2\timport type { Photo } from './db';\n3\t\n4\texport const MAX_LIMIT = 60;\n5\texport const DEFAULT_LIMIT = 20;\n6\t\n7\t/** Fields needed to persist a freshly uploaded photo. */\n8\texport interface NewPhoto {\n9\t\tid: string;\n10\t\tr2_key: string;\n11\t\tname: string | null;\n12\t\tcreated_at: number;\n13\t}\n14\t\n15\t/** Max length we store for a client-supplied display name. */\n16\texport const MAX_NAME_LENGTH = 80;\n17\t\n18\t/**\n19\t * Normalize a client-supplied name: strip control characters, trim, and cap\n20\t * the length. Returns null for missing or effectively empty names — we never\n21\t * trust the raw value.\n22\t */\n23\texport function sanitizeName(raw: FormDataEntryValue | null): string | null {\n24\t\tif (typeof raw !== 'string') {\n25\t\t\treturn null;\n26\t\t}\n27\t\t// Drop ASCII control characters (incl. newlines/tabs and DEL) before trimming.\n28\t\tconst cleaned = Array.from(raw)\n29\t\t\t.filter((ch) => {\n30\t\t\t\tconst code = ch.charCodeAt(0);\n31\t\t\t\treturn code >= 0x20 && code !== 0x7f;\n32\t\t\t})\n33\t\t\t.join('')\n34\t\t\t.trim();\n35\t\tif (cleaned.length === 0) {\n36\t\t\treturn null;\n37\t\t}\n38\t\treturn cleaned.slice(0, MAX_NAME_LENGTH);\n39\t}\n40\t\n41\t/** Build the public URL for a stored R2 object. */\n42\texport function publicUrl(base: string, r2_key: string): string {\n43\t\treturn `${base.replace(/\\/+$/, '')}/${r2_key}`;\n44\t}\n45\t\n46\t/** Insert a new photo metadata row. Rows default to visible (hidden = 0). */\n47\texport async function insertPhoto(db: D1Database, photo: NewPhoto): Promise<void> {\n48\t\tawait db\n49\t\t\t.prepare('INSERT INTO photos (id, r2_key, name, created_at, hidden) VALUES (?, ?, ?, ?, 0)')\n50\t\t\t.bind(photo.id, photo.r2_key, photo.name, photo.created_at)\n51\t\t\t.run();\n52\t}\n53\t\n54\t/** Shape returned to the client after a successful upload. */\n55\texport interface PhotoResponse {\n56\t\tid: string;\n57\t\turl: string;\n58\t\tname: string | null;\n59\t\tcreatedAt: number;\n60\t}\n61\t\n62\t/** Map a stored photo row to its public-facing response shape. */\n63\texport function toPhotoResponse(photo: Photo, base: string): PhotoResponse {\n64\t\treturn {\n65\t\t\tid: photo.id,\n66\t\t\turl: publicUrl(base, photo.r2_key),\n67\t\t\tname: photo.name,\n68\t\t\tcreatedAt: photo.created_at\n69\t\t};\n70\t}\n71\t\n72\texport interface PhotoListResponse {\n73\t\tphotos: PhotoResponse[];\n74\t\tnextBefore: number | null;\n75\t}\n76\t\n77\t/**\n78\t * List non-hidden photos newest-first with cursor pagination.\n79\t * Fetches up to limit rows (clamped to MAX_LIMIT); pass before to continue\n80\t * from a previous page.\n81\t */\n82\texport async function listPhotos(\n83\t\tdb: D1Database,\n84\t\tbase: string,\n85\t\tbefore: number | null,\n86\t\tlimit: number\n87\t): Promise<PhotoListResponse> {\n88\t\tconst clampedLimit = Math.min(Math.max(1, limit), MAX_LIMIT);\n89\t\tconst fetchLimit = clampedLimit + 1;\n90\t\n91\t\tlet rows: Photo[];\n92\t\tif (before !== null) {\n93\t\t\trows = (\n94\t\t\t\tawait db\n95\t\t\t\t\t.prepare(\n96\t\t\t\t\t\t'SELECT * FROM photos WHERE hidden = 0 AND created_at < ? ORDER BY created_at DESC LIMIT ?'\n97\t\t\t\t\t)\n98\t\t\t\t\t.bind(before, fetchLimit)\n99\t\t\t\t\t.all<Photo>()\n100\t\t\t).results;\n101\t\t} else {\n102\t\t\trows = (\n103\t\t\t\tawait db\n104\t\t\t\t\t.prepare('SELECT * FROM photos WHERE hidden = 0 ORDER BY created_at DESC LIMIT ?')\n105\t\t\t\t\t.bind(fetchLimit)\n106\t\t\t\t\t.all<Photo>()\n107\t\t\t).results;\n108\t\t}\n109\t\n110\t\tconst hasMore = rows.length > clampedLimit;\n111\t\tconst photos = rows.slice(0, clampedLimit).map((row) => toPhotoResponse(row, base));\n112\t\tconst nextBefore = hasMore ? rows[clampedLimit].created_at : null;\n113\t\n114\t\treturn { photos, nextBefore };\n115\t}\n116\t"}]},"parent_tool_use_id":null,"session_id":"8cf19ab8-5bc3-4c8c-ba52-927e10d08336","uuid":"244461a1-8a81-45e0-a2f7-90cc61bb142d","timestamp":"2026-05-26T15:07:27.545Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/lib/server/photos.ts","content":"import type { D1Database } from '@cloudflare/workers-types';\nimport type { Photo } from './db';\n\nexport const MAX_LIMIT = 60;\nexport const DEFAULT_LIMIT = 20;\n\n/** Fields needed to persist a freshly uploaded photo. */\nexport interface NewPhoto {\n\tid: string;\n\tr2_key: string;\n\tname: string | null;\n\tcreated_at: number;\n}\n\n/** Max length we store for a client-supplied display name. */\nexport const MAX_NAME_LENGTH = 80;\n\n/**\n * Normalize a client-supplied name: strip control characters, trim, and cap\n * the length. Returns null for missing or effectively empty names — we never\n * trust the raw value.\n */\nexport function sanitizeName(raw: FormDataEntryValue | null): string | null {\n\tif (typeof raw !== 'string') {\n\t\treturn null;\n\t}\n\t// Drop ASCII control characters (incl. newlines/tabs and DEL) before trimming.\n\tconst cleaned = Array.from(raw)\n\t\t.filter((ch) => {\n\t\t\tconst code = ch.charCodeAt(0);\n\t\t\treturn code >= 0x20 && code !== 0x7f;\n\t\t})\n\t\t.join('')\n\t\t.trim();\n\tif (cleaned.length === 0) {\n\t\treturn null;\n\t}\n\treturn cleaned.slice(0, MAX_NAME_LENGTH);\n}\n\n/** Build the public URL for a stored R2 object. */\nexport function publicUrl(base: string, r2_key: string): string {\n\treturn `${base.replace(/\\/+$/, '')}/${r2_key}`;\n}\n\n/** Insert a new photo metadata row. Rows default to visible (hidden = 0). */\nexport async function insertPhoto(db: D1Database, photo: NewPhoto): Promise<void> {\n\tawait db\n\t\t.prepare('INSERT INTO photos (id, r2_key, name, created_at, hidden) VALUES (?, ?, ?, ?, 0)')\n\t\t.bind(photo.id, photo.r2_key, photo.name, photo.created_at)\n\t\t.run();\n}\n\n/** Shape returned to the client after a successful upload. */\nexport interface PhotoResponse {\n\tid: string;\n\turl: string;\n\tname: string | null;\n\tcreatedAt: number;\n}\n\n/** Map a stored photo row to its public-facing response shape. */\nexport function toPhotoResponse(photo: Photo, base: string): PhotoResponse {\n\treturn {\n\t\tid: photo.id,\n\t\turl: publicUrl(base, photo.r2_key),\n\t\tname: photo.name,\n\t\tcreatedAt: photo.created_at\n\t};\n}\n\nexport interface PhotoListResponse {\n\tphotos: PhotoResponse[];\n\tnextBefore: number | null;\n}\n\n/**\n * List non-hidden photos newest-first with cursor pagination.\n * Fetches up to limit rows (clamped to MAX_LIMIT); pass before to continue\n * from a previous page.\n */\nexport async function listPhotos(\n\tdb: D1Database,\n\tbase: string,\n\tbefore: number | null,\n\tlimit: number\n): Promise<PhotoListResponse> {\n\tconst clampedLimit = Math.min(Math.max(1, limit), MAX_LIMIT);\n\tconst fetchLimit = clampedLimit + 1;\n\n\tlet rows: Photo[];\n\tif (before !== null) {\n\t\trows = (\n\t\t\tawait db\n\t\t\t\t.prepare(\n\t\t\t\t\t'SELECT * FROM photos WHERE hidden = 0 AND created_at < ? ORDER BY created_at DESC LIMIT ?'\n\t\t\t\t)\n\t\t\t\t.bind(before, fetchLimit)\n\t\t\t\t.all<Photo>()\n\t\t).results;\n\t} else {\n\t\trows = (\n\t\t\tawait db\n\t\t\t\t.prepare('SELECT * FROM photos WHERE hidden = 0 ORDER BY created_at DESC LIMIT ?')\n\t\t\t\t.bind(fetchLimit)\n\t\t\t\t.all<Photo>()\n\t\t).results;\n\t}\n\n\tconst hasMore = rows.length > clampedLimit;\n\tconst photos = rows.slice(0, clampedLimit).map((row) => toPhotoResponse(row, base));\n\tconst nextBefore = hasMore ? rows[clampedLimit].created_at : null;\n\n\treturn { photos, nextBefore };\n}\n","numLines":116,"startLine":1,"totalLines":116}}}
