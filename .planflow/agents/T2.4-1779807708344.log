{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019k8fkUyg1t66xT3Sn3izGd","type":"tool_result","content":"1\timport { error, json } from '@sveltejs/kit';\n2\timport { getDb } from '$lib/server/db';\n3\timport { requireEnv } from '$lib/server/env';\n4\timport { insertPhoto, publicUrl, sanitizeName, type PhotoResponse } from '$lib/server/photos';\n5\timport type { RequestHandler } from './$types';\n6\t\n7\t/** Maximum accepted upload size — matches the client-side compression cap. */\n8\tconst MAX_BYTES = 8 * 1024 * 1024;\n9\t\n10\t/**\n11\t * POST /api/upload\n12\t *\n13\t * Accepts a multipart/form-data body with a required `photo` File and an\n14\t * optional `name`. Validates the content type and size, stores the blob in R2\n15\t * under a server-generated key, persists a metadata row in D1, and returns the\n16\t * created record with its public URL.\n17\t */\n18\texport const POST: RequestHandler = async ({ request, platform }) => {\n19\t\tconst db = getDb(platform);\n20\t\tconst bucket = requireEnv(platform, 'PHOTOS_BUCKET');\n21\t\tconst publicBase = requireEnv(platform, 'R2_PUBLIC_BASE_URL');\n22\t\n23\t\tlet form: FormData;\n24\t\ttry {\n25\t\t\tform = await request.formData();\n26\t\t} catch {\n27\t\t\tthrow error(400, 'Expected multipart/form-data');\n28\t\t}\n29\t\n30\t\tconst photo = form.get('photo');\n31\t\tif (!(photo instanceof File)) {\n32\t\t\tthrow error(400, 'Missing photo file');\n33\t\t}\n34\t\n35\t\tif (!photo.type.startsWith('image/')) {\n36\t\t\tthrow error(400, 'Uploaded file must be an image');\n37\t\t}\n38\t\n39\t\tif (photo.size === 0) {\n40\t\t\tthrow error(400, 'Uploaded file is empty');\n41\t\t}\n42\t\n43\t\tif (photo.size > MAX_BYTES) {\n44\t\t\tthrow error(400, 'Uploaded file exceeds the 8MB limit');\n45\t\t}\n46\t\n47\t\tconst name = sanitizeName(form.get('name'));\n48\t\tconst id = crypto.randomUUID();\n49\t\t// Never trust the client filename — derive the key from a fresh UUID.\n50\t\tconst r2Key = `photos/${id}.jpg`;\n51\t\tconst createdAt = Date.now();\n52\t\n53\t\tconst bytes = await photo.arrayBuffer();\n54\t\tawait bucket.put(r2Key, bytes, {\n55\t\t\thttpMetadata: { contentType: photo.type }\n56\t\t});\n57\t\n58\t\tawait insertPhoto(db, { id, r2_key: r2Key, name, created_at: createdAt });\n59\t\n60\t\tconst body: PhotoResponse = {\n61\t\t\tid,\n62\t\t\turl: publicUrl(publicBase, r2Key),\n63\t\t\tname,\n64\t\t\tcreatedAt\n65\t\t};\n66\t\treturn json(body, { status: 201 });\n67\t};\n68\t"}]},"parent_tool_use_id":null,"session_id":"798487e0-7ce7-451a-912a-cc7ce738465a","uuid":"7c13ecbd-d1d4-4667-b2ed-a24efa78b33c","timestamp":"2026-05-26T15:02:03.904Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/routes/api/upload/+server.ts","content":"import { error, json } from '@sveltejs/kit';\nimport { getDb } from '$lib/server/db';\nimport { requireEnv } from '$lib/server/env';\nimport { insertPhoto, publicUrl, sanitizeName, type PhotoResponse } from '$lib/server/photos';\nimport type { RequestHandler } from './$types';\n\n/** Maximum accepted upload size — matches the client-side compression cap. */\nconst MAX_BYTES = 8 * 1024 * 1024;\n\n/**\n * POST /api/upload\n *\n * Accepts a multipart/form-data body with a required `photo` File and an\n * optional `name`. Validates the content type and size, stores the blob in R2\n * under a server-generated key, persists a metadata row in D1, and returns the\n * created record with its public URL.\n */\nexport const POST: RequestHandler = async ({ request, platform }) => {\n\tconst db = getDb(platform);\n\tconst bucket = requireEnv(platform, 'PHOTOS_BUCKET');\n\tconst publicBase = requireEnv(platform, 'R2_PUBLIC_BASE_URL');\n\n\tlet form: FormData;\n\ttry {\n\t\tform = await request.formData();\n\t} catch {\n\t\tthrow error(400, 'Expected multipart/form-data');\n\t}\n\n\tconst photo = form.get('photo');\n\tif (!(photo instanceof File)) {\n\t\tthrow error(400, 'Missing photo file');\n\t}\n\n\tif (!photo.type.startsWith('image/')) {\n\t\tthrow error(400, 'Uploaded file must be an image');\n\t}\n\n\tif (photo.size === 0) {\n\t\tthrow error(400, 'Uploaded file is empty');\n\t}\n\n\tif (photo.size > MAX_BYTES) {\n\t\tthrow error(400, 'Uploaded file exceeds the 8MB limit');\n\t}\n\n\tconst name = sanitizeName(form.get('name'));\n\tconst id = crypto.randomUUID();\n\t// Never trust the client filename — derive the key from a fresh UUID.\n\tconst r2Key = `photos/${id}.jpg`;\n\tconst createdAt = Date.now();\n\n\tconst bytes = await photo.arrayBuffer();\n\tawait bucket.put(r2Key, bytes, {\n\t\thttpMetadata: { contentType: photo.type }\n\t});\n\n\tawait insertPhoto(db, { id, r2_key: r2Key, name, created_at: createdAt });\n\n\tconst body: PhotoResponse = {\n\t\tid,\n\t\turl: publicUrl(publicBase, r2Key),\n\t\tname,\n\t\tcreatedAt\n\t};\n\treturn json(body, { status: 201 });\n};\n","numLines":68,"startLine":1,"totalLines":68}}}
