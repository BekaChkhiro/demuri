.slice(0, clampedLimit).map((row) => toPhotoResponse(row, base));\n\tconst nextBefore = hasMore ? rows[clampedLimit].created_at : null;\n\n\treturn { photos, nextBefore };\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":607,"cache_read_input_tokens":40585,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":607},"output_tokens":67,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"798487e0-7ce7-451a-912a-cc7ce738465a","uuid":"44bf32d1-3ef5-4bff-be57-32c855f08850","request_id":"req_011CbRPBrbRpr4C3u313tJiU"}
