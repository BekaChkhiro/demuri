{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TV93eGQEw72GbhVA3tU9vW","type":"tool_result","content":"1\timport type { D1Database } from '@cloudflare/workers-types';\n2\timport type { Photo } from './db';\n3\t\n4\t/** Fields needed to persist a freshly uploaded photo. */\n5\texport interface NewPhoto {\n6\t\tid: string;\n7\t\tr2_key: string;\n8\t\tname: string | null;\n9\t\tcreated_at: number;\n10\t}\n11\t\n12\t/** Max length we store for a client-supplied display name. */\n13\texport const MAX_NAME_LENGTH = 80;\n14\t\n15\t/**\n16\t * Normalize a client-supplied name: strip control characters, trim, and cap\n17\t * the length. Returns null for missing or effectively empty names — we never\n18\t * trust the raw value.\n19\t */\n20\texport function sanitizeName(raw: FormDataEntryValue | null): string | null {\n21\t\tif (typeof raw !== 'string') {\n22\t\t\treturn null;\n23\t\t}\n24\t\t// Drop ASCII control characters (incl. newlines/tabs and DEL) before trimming.\n25\t\tconst cleaned = Array.from(raw)\n26\t\t\t.filter((ch) => {\n27\t\t\t\tconst code = ch.charCodeAt(0);\n28\t\t\t\treturn code >= 0x20 && code !== 0x7f;\n29\t\t\t})\n30\t\t\t.join('')\n31\t\t\t.trim();\n32\t\tif (cleaned.length === 0) {\n33\t\t\treturn null;\n34\t\t}\n35\t\treturn cleaned.slice(0, MAX_NAME_LENGTH);\n36\t}\n37\t\n38\t/** Build the public URL for a stored R2 object. */\n39\texport function publicUrl(base: string, r2_key: string): string {\n40\t\treturn `${base.replace(/\\/+$/, '')}/${r2_key}`;\n41\t}\n42\t\n43\t/** Insert a new photo metadata row. Rows default to visible (hidden = 0). */\n44\texport async function insertPhoto(db: D1Database, photo: NewPhoto): Promise<void> {\n45\t\tawait db\n46\t\t\t.prepare('INSERT INTO photos (id, r2_key, name, created_at, hidden) VALUES (?, ?, ?, ?, 0)')\n47\t\t\t.bind(photo.id, photo.r2_key, photo.name, photo.created_at)\n48\t\t\t.run();\n49\t}\n50\t\n51\t/** Shape returned to the client after a successful upload. */\n52\texport interface PhotoResponse {\n53\t\tid: string;\n54\t\turl: string;\n55\t\tname: string | null;\n56\t\tcreatedAt: number;\n57\t}\n58\t\n59\t/** Map a stored photo row to its public-facing response shape. */\n60\texport function toPhotoResponse(photo: Photo, base: string): PhotoResponse {\n61\t\treturn {\n62\t\t\tid: photo.id,\n63\t\t\turl: publicUrl(base, photo.r2_key),\n64\t\t\tname: photo.name,\n65\t\t\tcreatedAt: photo.created_at\n66\t\t};\n67\t}\n68\t"}]},"parent_tool_use_id":null,"session_id":"798487e0-7ce7-451a-912a-cc7ce738465a","uuid":"5a3c7d2f-ceb1-405c-9c8f-ede688211fa7","timestamp":"2026-05-26T15:02:04.486Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/lib/server/photos.ts","content":"import type { D1Database } from '@cloudflare/workers-types';\nimport type { Photo } from './db';\n\n/** Fields needed to persist a freshly uploaded photo. */\nexport interface NewPhoto {\n\tid: string;\n\tr2_key: string;\n\tname: string | null;\n\tcreated_at: number;\n}\n\n/** Max length we store for a client-supplied display name. */\nexport const MAX_NAME_LENGTH = 80;\n\n/**\n * Normalize a client-supplied name: strip control characters, trim, and cap\n * the length. Returns null for missing or effectively empty names — we never\n * trust the raw value.\n */\nexport function sanitizeName(raw: FormDataEntryValue | null): string | null {\n\tif (typeof raw !== 'string') {\n\t\treturn null;\n\t}\n\t// Drop ASCII control characters (incl. newlines/tabs and DEL) before trimming.\n\tconst cleaned = Array.from(raw)\n\t\t.filter((ch) => {\n\t\t\tconst code = ch.charCodeAt(0);\n\t\t\treturn code >= 0x20 && code !== 0x7f;\n\t\t})\n\t\t.join('')\n\t\t.trim();\n\tif (cleaned.length === 0) {\n\t\treturn null;\n\t}\n\treturn cleaned.slice(0, MAX_NAME_LENGTH);\n}\n\n/** Build the public URL for a stored R2 object. */\nexport function publicUrl(base: string, r2_key: string): string {\n\treturn `${base.replace(/\\/+$/, '')}/${r2_key}`;\n}\n\n/** Insert a new photo metadata row. Rows default to visible (hidden = 0). */\nexport async function insertPhoto(db: D1Database, photo: NewPhoto): Promise<void> {\n\tawait db\n\t\t.prepare('INSERT INTO photos (id, r2_key, name, created_at, hidden) VALUES (?, ?, ?, ?, 0)')\n\t\t.bind(photo.id, photo.r2_key, photo.name, photo.created_at)\n\t\t.run();\n}\n\n/** Shape returned to the client after a successful upload. */\nexport interface PhotoResponse {\n\tid: string;\n\turl: string;\n\tname: string | null;\n\tcreatedAt: number;\n}\n\n/** Map a stored photo row to its public-facing response shape. */\nexport function toPhotoResponse(photo: Photo, base: string): PhotoResponse {\n\treturn {\n\t\tid: photo.id,\n\t\turl: publicUrl(base, photo.r2_key),\n\t\tname: photo.name,\n\t\tcreatedAt: photo.created_at\n\t};\n}\n","numLines":68,"startLine":1,"totalLines":68}}}
