\t// SvelteKit's Cloudflare worker passes straight back to the client.\n\treturn stub.fetch(request) as unknown as Promise<Response>;\n};\n","structuredPatch":[{"oldStart":20,"oldLines":6,"newStart":20,"newLines":7,"lines":["   const stub = env.GALLERY.get(id);"," ","   // Forward the upgrade to the DO; it returns the 101 + client socket, which","-  // SvelteKit's Cloudflare worker passes straight back to the client.","-  return stub.fetch(request) as unknown as Promise<Response>;","+  // SvelteKit's Cloudflare worker passes straight back to the client. The DO","+  // stub speaks the Cloudflare Request/Response types, hence the boundary cast.","+  return stub.fetch(request as never) as unknown as Promise<Response>;"," };"]}],"userModified":false,"replaceAll":false}}
