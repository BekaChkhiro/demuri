{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019cMhZTk3tBMsQf1kWBs7RF","type":"tool_result","content":"1\timport { error, json } from '@sveltejs/kit';\n2\timport { getDb } from '$lib/server/db';\n3\timport { requireEnv } from '$lib/server/env';\n4\timport { getPhotoById, setPhotoHidden, deletePhotoRow } from '$lib/server/photos';\n5\timport type { RequestHandler } from './$types';\n6\t\n7\t/**\n8\t * PATCH /api/admin/photos/:id\n9\t *\n10\t * Body: { hidden: boolean }\n11\t * Sets the hidden flag on the photo. Returns 200 on success, 404 if not found.\n12\t * Auth is enforced by hooks.server.ts for all /api/admin/* routes.\n13\t */\n14\texport const PATCH: RequestHandler = async ({ params, request, platform }) => {\n15\t\tconst db = getDb(platform);\n16\t\n17\t\tlet body: unknown;\n18\t\ttry {\n19\t\t\tbody = await request.json();\n20\t\t} catch {\n21\t\t\tthrow error(400, 'Expected JSON body');\n22\t\t}\n23\t\n24\t\tif (typeof body !== 'object' || body === null || typeof (body as Record<string, unknown>).hidden !== 'boolean') {\n25\t\t\tthrow error(400, 'Body must be { hidden: boolean }');\n26\t\t}\n27\t\n28\t\tconst hidden = (body as { hidden: boolean }).hidden;\n29\t\tconst updated = await setPhotoHidden(db, params.id, hidden);\n30\t\n31\t\tif (!updated) {\n32\t\t\tthrow error(404, 'Photo not found');\n33\t\t}\n34\t\n35\t\treturn json({ id: params.id, hidden });\n36\t};\n37\t\n38\t/**\n39\t * DELETE /api/admin/photos/:id\n40\t *\n41\t * Removes the R2 object first, then the D1 row to avoid orphaned blobs.\n42\t * Returns 200 on success, 404 if not found. Idempotent — a repeat delete\n43\t * after the row is gone returns 404.\n44\t */\n45\texport const DELETE: RequestHandler = async ({ params, platform }) => {\n46\t\tconst db = getDb(platform);\n47\t\tconst bucket = requireEnv(platform, 'PHOTOS_BUCKET');\n48\t\n49\t\tconst photo = await getPhotoById(db, params.id);\n50\t\tif (!photo) {\n51\t\t\tthrow error(404, 'Photo not found');\n52\t\t}\n53\t\n54\t\t// Remove from R2 before D1 to avoid orphaned blobs.\n55\t\tawait bucket.delete(photo.r2_key);\n56\t\tawait deletePhotoRow(db, params.id);\n57\t\n58\t\treturn json({ id: params.id, deleted: true });\n59\t};\n60\t"}]},"parent_tool_use_id":null,"session_id":"c160fba4-ee3f-4c65-8d1e-7eb42a4ac504","uuid":"84e46c82-74da-4d56-825b-14f4b8ab5792","timestamp":"2026-05-26T16:16:17.257Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/routes/api/admin/photos/[id]/+server.ts","content":"import { error, json } from '@sveltejs/kit';\nimport { getDb } from '$lib/server/db';\nimport { requireEnv } from '$lib/server/env';\nimport { getPhotoById, setPhotoHidden, deletePhotoRow } from '$lib/server/photos';\nimport type { RequestHandler } from './$types';\n\n/**\n * PATCH /api/admin/photos/:id\n *\n * Body: { hidden: boolean }\n * Sets the hidden flag on the photo. Returns 200 on success, 404 if not found.\n * Auth is enforced by hooks.server.ts for all /api/admin/* routes.\n */\nexport const PATCH: RequestHandler = async ({ params, request, platform }) => {\n\tconst db = getDb(platform);\n\n\tlet body: unknown;\n\ttry {\n\t\tbody = await request.json();\n\t} catch {\n\t\tthrow error(400, 'Expected JSON body');\n\t}\n\n\tif (typeof body !== 'object' || body === null || typeof (body as Record<string, unknown>).hidden !== 'boolean') {\n\t\tthrow error(400, 'Body must be { hidden: boolean }');\n\t}\n\n\tconst hidden = (body as { hidden: boolean }).hidden;\n\tconst updated = await setPhotoHidden(db, params.id, hidden);\n\n\tif (!updated) {\n\t\tthrow error(404, 'Photo not found');\n\t}\n\n\treturn json({ id: params.id, hidden });\n};\n\n/**\n * DELETE /api/admin/photos/:id\n *\n * Removes the R2 object first, then the D1 row to avoid orphaned blobs.\n * Returns 200 on success, 404 if not found. Idempotent — a repeat delete\n * after the row is gone returns 404.\n */\nexport const DELETE: RequestHandler = async ({ params, platform }) => {\n\tconst db = getDb(platform);\n\tconst bucket = requireEnv(platform, 'PHOTOS_BUCKET');\n\n\tconst photo = await getPhotoById(db, params.id);\n\tif (!photo) {\n\t\tthrow error(404, 'Photo not found');\n\t}\n\n\t// Remove from R2 before D1 to avoid orphaned blobs.\n\tawait bucket.delete(photo.r2_key);\n\tawait deletePhotoRow(db, params.id);\n\n\treturn json({ id: params.id, deleted: true });\n};\n","numLines":60,"startLine":1,"totalLines":60}}}
