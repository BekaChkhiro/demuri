{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01SmGMM13JALt11iM31NqgLR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018b7QANZyKKxyZDgeGFAGdf","name":"Write","input":{"file_path":"/Users/beqolozi/Desktop/demuri/src/lib/compress.ts","content":"export async function compressImage(\n\tblob: Blob,\n\tmaxEdge = 1600,\n\tquality = 0.82\n): Promise<Blob> {\n\tconst bitmap = await createImageBitmap(blob);\n\tconst { width, height } = bitmap;\n\n\tconst longest = Math.max(width, height);\n\tif (longest <= maxEdge) {\n\t\tbitmap.close();\n\t\treturn blob;\n\t}\n\n\tconst scale = maxEdge / longest;\n\tconst targetW = Math.round(width * scale);\n\tconst targetH = Math.round(height * scale);\n\n\tconst canvas = new OffscreenCanvas(targetW, targetH);\n\tconst ctx = canvas.getContext('2d');\n\tif (!ctx) {\n\t\tbitmap.close();\n\t\treturn blob;\n\t}\n\n\tctx.drawImage(bitmap, 0, 0, targetW, targetH);\n\tbitmap.close();\n\n\tconst compressed = await canvas.convertToBlob({ type: 'image/jpeg', quality });\n\treturn compressed.size < blob.size ? compressed : blob;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":941,"cache_read_input_tokens":38857,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":941},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ea746011-e2da-411a-a601-bcf47b9ec4d4","uuid":"7c220495-8351-4521-a520-d05684436d3d","request_id":"req_011CbRNRrFsAZ9Uaky8vPe7y"}
