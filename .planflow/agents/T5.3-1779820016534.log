US\" = \"DIRTY\" ]; then\n      POLL_OUTCOME=\"DIRTY\"\n      break\n    fi\n\n    if [ \"$CHECKS_FAILED\" -gt 0 ]; then\n      POLL_OUTCOME=\"CI_FAILED\"\n      FAILED_RUN_URL=$(echo \"$PR_JSON\" | grep -B1 '\"conclusion\":\"FAILURE\"' | grep '\"detailsUrl\"' | head -1 | grep -o 'https://[^\"]*')\n      break\n    fi\n\n    if [ \"$AUTO_MERGE_REARMED\" = \"false\" ]; then\n      MERGEABLE_GREEN_COUNT=$((MERGEABLE_GREEN_COUNT + 1))\n      if [ $MERGEABLE_GREEN_COUNT -ge 3 ]; then\n        POLL_OUTCOME=\"AWAITING_MANUAL_MERGE\"\n        PR_FINAL_STATE=\"AWAITING_MANUAL_MERGE\"\n        break\n      fi\n    fi\n\n    sleep $INTERVAL\n  done\n\n  if [ \"$POLL_OUTCOME\" = \"MERGED\" ] || [ \"$POLL_OUTCOME\" = \"CLOSED\" ] || [ \"$POLL_OUTCOME\" = \"AWAITING_MANUAL_MERGE\" ]; then\n    break\n  fi\n\n  if [ -z \"$POLL_OUTCOME\" ]; then\n    PR_FINAL_STATE=\"TIMEOUT_AFTER_${OVERALL_TIMEOUT}S\"\n    break\n  fi\n\n  if [ $RECOVERIES -ge $MAX_RECOVERIES ]; then\n    PR_FINAL_STATE=\"MAX_RECOVERIES_EXCEEDED_${POLL_OUTCOME}\"\n    break\n  fi\n\n  RECOVERIES=$((RECOVERIES + 1))\n  echo \"Recovery attempt $RECOVERIES/$MAX_RECOVERIES — outcome was $POLL_OUTCOME\"\n  echo \"RECOVERY_NEEDED=$POLL_OUTCOME\"\n  if [ -n \"$FAILED_RUN_URL\" ]; then\n    echo \"FAILED_RUN_URL=$FAILED_RUN_URL\"\n  fi\n  break\ndone\n\necho \"---\"\necho \"PR_MERGED=$PR_MERGED\"\necho \"PR_FINAL_STATE=$PR_FINAL_STATE\"\necho \"PR_MERGE_COMMIT=$PR_MERGE_COMMIT\"\necho \"RECOVERIES=$RECOVERIES\"","description":"Poll PR for merge with self-healing recovery loop","timeout":600000},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":372,"cache_read_input_tokens":50766,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":372},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"edda3782-