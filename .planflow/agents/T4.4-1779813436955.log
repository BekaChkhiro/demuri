t\t\t\t\tDelete\n\t\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t{/each}\n\t\t\t</div>\n\t\t{/if}\n\t</section>\n</main>\n\n{#if confirmDeleteId !== null}\n\t<div\n\t\tclass=\"overlay\"\n\t\trole=\"dialog\"\n\t\taria-modal=\"true\"\n\t\taria-label=\"Confirm deletion\"\n\t\tonclick={() => (confirmDeleteId = null)}\n\t\tonkeydown={(e) => e.key === 'Escape' && (confirmDeleteId = null)}\n\t\ttabindex=\"-1\"\n\t>\n\t\t<div class=\"dialog\" onclick={(e) => e.stopPropagation()} onkeydown={() => {}}>\n\t\t\t<h2>Delete photo?</h2>\n\t\t\t<p>\n\t\t\t\t{#if confirmPhoto?.name}\n\t\t\t\t\t<strong>{confirmPhoto.name}</strong> will be\n\t\t\t\t{:else}\n\t\t\t\t\tThis photo will be\n\t\t\t\t{/if}\n\t\t\t\tpermanently removed. This cannot be undone.\n\t\t\t</p>\n\t\t\t<div class=\"dialog-actions\">\n\t\t\t\t<button class=\"btn btn-secondary\" onclick={() => (confirmDeleteId = null)}>Cancel</button>\n\t\t\t\t<button\n\t\t\t\t\tclass=\"btn btn-danger\"\n\t\t\t\t\tonclick={() => confirmDeleteId && confirmAndDelete(confirmDeleteId)}\n\t\t\t\t>\n\t\t\t\t\tDelete permanently\n\t\t\t\t</button>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n{/if}\n\n<style>\n\t:global(body) {\n\t\tmargin: 0;\n\t\tbackground: #0a0a0a;\n\t\tcolor: #e0e0e0;\n\t\tfont-family:\n\t\t\tsystem-ui,\n\t\t\t-apple-system,\n\t\t\tsans-serif;\n\t\tmin-height: 100dvh;\n\t}\n\n\tmain {\n\t\tmax-width: 1100px;\n\t\tmargin: 0 auto;\n\t\tpadding: 1.5rem 1rem 3rem;\n\t\tdisplay: flex;\n\t\tflex-direction: column;\n\t\tgap: 1.5rem;\n\t}\n\n\theader {\n\t\tborder-bottom: 1px solid #1a1a1a;\n\t\tpadding-bottom: 1rem;\n\t}\n\n\t.header-row {\n\t\tdisplay: flex;\n\t\tjustify-content: space-between;\n\t\talign-items: flex-start;\n\t}\n\n\th1 {\n\t\tmargin: 0 0 0.25rem;\n\t\tfont-size: 1.75rem;\n\t\tfont-weight: 800;\n\t\tcolor: #39ff14;\n\t\tletter-spacing: -0.02em;\n\t}\n\n\t.subtitle {\n\t\tmargin: 0;\n\t\tcolor: #666;\n\t\tfont-size: 0.9rem;\n\t}\n\n\t.logout-link {\n\t\tcolor: #666;\n\t\tf