{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TsHgdYhoQJT636vUD4Mcyo","type":"tool_result","content":"1\texport async function compressImage(\n2\t\tblob: Blob,\n3\t\tmaxEdge = 1600,\n4\t\tquality = 0.82\n5\t): Promise<Blob> {\n6\t\tconst bitmap = await createImageBitmap(blob);\n7\t\tconst { width, height } = bitmap;\n8\t\n9\t\tconst longest = Math.max(width, height);\n10\t\tif (longest <= maxEdge) {\n11\t\t\tbitmap.close();\n12\t\t\treturn blob;\n13\t\t}\n14\t\n15\t\tconst scale = maxEdge / longest;\n16\t\tconst targetW = Math.round(width * scale);\n17\t\tconst targetH = Math.round(height * scale);\n18\t\n19\t\tconst canvas = new OffscreenCanvas(targetW, targetH);\n20\t\tconst ctx = canvas.getContext('2d');\n21\t\tif (!ctx) {\n22\t\t\tbitmap.close();\n23\t\t\treturn blob;\n24\t\t}\n25\t\n26\t\tctx.drawImage(bitmap, 0, 0, targetW, targetH);\n27\t\tbitmap.close();\n28\t\n29\t\tconst compressed = await canvas.convertToBlob({ type: 'image/jpeg', quality });\n30\t\treturn compressed.size < blob.size ? compressed : blob;\n31\t}\n32\t"}]},"parent_tool_use_id":null,"session_id":"030b6fc9-c9e8-4e2e-99dd-8fcb5146f8e5","uuid":"3c8a2a6a-ae45-4bed-8da6-a9dd8e88fd0d","timestamp":"2026-05-26T14:57:21.093Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/lib/compress.ts","content":"export async function compressImage(\n\tblob: Blob,\n\tmaxEdge = 1600,\n\tquality = 0.82\n): Promise<Blob> {\n\tconst bitmap = await createImageBitmap(blob);\n\tconst { width, height } = bitmap;\n\n\tconst longest = Math.max(width, height);\n\tif (longest <= maxEdge) {\n\t\tbitmap.close();\n\t\treturn blob;\n\t}\n\n\tconst scale = maxEdge / longest;\n\tconst targetW = Math.round(width * scale);\n\tconst targetH = Math.round(height * scale);\n\n\tconst canvas = new OffscreenCanvas(targetW, targetH);\n\tconst ctx = canvas.getContext('2d');\n\tif (!ctx) {\n\t\tbitmap.close();\n\t\treturn blob;\n\t}\n\n\tctx.drawImage(bitmap, 0, 0, targetW, targetH);\n\tbitmap.close();\n\n\tconst compressed = await canvas.convertToBlob({ type: 'image/jpeg', quality });\n\treturn compressed.size < blob.size ? compressed : blob;\n}\n","numLines":32,"startLine":1,"totalLines":32}}}
