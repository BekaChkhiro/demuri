{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_017unjV6kPJMn2VjvcunCp1W","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TWFH59KwYA1MK7bhc9ouW7","name":"Write","input":{"file_path":"/Users/beqolozi/Desktop/demuri/src/lib/server/photos.ts","content":"import type { D1Database } from '@cloudflare/workers-types';\nimport type { Photo } from './db';\n\n/** Fields needed to persist a freshly uploaded photo. */\nexport interface NewPhoto {\n\tid: string;\n\tr2_key: string;\n\tname: string | null;\n\tcreated_at: number;\n}\n\n/** Max length we store for a client-supplied display name. */\nexport const MAX_NAME_LENGTH = 80;\n\n/**\n * Normalize a client-supplied name: trim, strip control characters, and cap\n * the length. Returns null for missing or effectively empty names — we never\n * trust the raw value.\n */\nexport function sanitizeName(raw: FormDataEntryValue | null): string | null {\n\tif (typeof raw !== 'string') {\n\t\treturn null;\n\t}\n\t// eslint-disable-next-line no-control-regex\n\tconst cleaned = raw.replace(/[\u0000-\u001f]/g, '').trim();\n\tif (cleaned.length === 0) {\n\t\treturn null;\n\t}\n\treturn cleaned.slice(0, MAX_NAME_LENGTH);\n}\n\n/** Build the public URL for a stored R2 object. */\nexport function publicUrl(base: string, r2_key: string): string {\n\treturn `${base.replace(/\\/+$/, '')}/${r2_key}`;\n}\n\n/** Insert a new photo metadata row. Rows default to visible (hidden = 0). */\nexport async function insertPhoto(db: D1Database, photo: NewPhoto): Promise<void> {\n\tawait db\n\t\t.prepare('INSERT INTO photos (id, r2_key, name, created_at, hidden) VALUES (?, ?, ?, ?, 0)')\n\t\t.bind(photo.id, photo.r2_key, photo.name, photo.created_at)\n\t\t.run();\n}\n\n/** Shape returned to the client after a successful upload. */\nexport interface PhotoResponse {\n\tid: string;\n\turl: string;\n\tname: string | null;\n\tcreatedAt: number;\n}\n\n/** Map a stored photo row to its public-facing response shape. */\nexport function toPhotoResponse(photo: Photo, base: string): PhotoResponse {\n\treturn {\n\t\tid: photo.id,\n\t\turl: publicUrl(base, photo.r2_key),\n\t\tname: photo.name,\n\t\tcreatedAt: photo.created_at\n\t};\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1275,"cache_read_input_tokens":45723,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1275},"output_tokens":63,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"030b6fc9-c9e8-4e2e-99dd-8fcb5146f8e5","uuid":"88eb9e95-a62d-4472-ad6e-6b76346cb226","request_id":"req_011CbRNpm8w2qUoyjagnD9Ni"}
