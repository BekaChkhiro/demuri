{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GKzXLdJcqir9Mjse3Tzhex","type":"tool_result","content":"1\texport const COOKIE_NAME = 'admin_session';\n2\t\n3\t// Fixed claim data signed by the ADMIN_PASSWORD key.\n4\tconst SESSION_CLAIM = new TextEncoder().encode('admin:v1');\n5\t\n6\tfunction timingSafeEqualBytes(a: Uint8Array, b: Uint8Array): boolean {\n7\t\tconst maxLen = Math.max(a.length, b.length);\n8\t\tlet diff = a.length ^ b.length;\n9\t\tfor (let i = 0; i < maxLen; i++) {\n10\t\t\tdiff |= (a[i] ?? 0) ^ (b[i] ?? 0);\n11\t\t}\n12\t\treturn diff === 0;\n13\t}\n14\t\n15\t/** Constant-time string comparison (UTF-8 byte level). */\n16\texport function timingSafeEqual(a: string, b: string): boolean {\n17\t\tconst enc = new TextEncoder();\n18\t\treturn timingSafeEqualBytes(enc.encode(a), enc.encode(b));\n19\t}\n20\t\n21\tasync function importHmacKey(password: string): Promise<CryptoKey> {\n22\t\treturn crypto.subtle.importKey(\n23\t\t\t'raw',\n24\t\t\tnew TextEncoder().encode(password),\n25\t\t\t{ name: 'HMAC', hash: 'SHA-256' },\n26\t\t\tfalse,\n27\t\t\t['sign', 'verify']\n28\t\t);\n29\t}\n30\t\n31\t/** Create a signed session token bound to the given admin password. */\n32\texport async function createSessionToken(adminPassword: string): Promise<string> {\n33\t\tconst key = await importHmacKey(adminPassword);\n34\t\tconst sig = await crypto.subtle.sign('HMAC', key, SESSION_CLAIM);\n35\t\treturn btoa(String.fromCharCode(...new Uint8Array(sig)));\n36\t}\n37\t\n38\t/**\n39\t * Verify a session token using constant-time HMAC comparison.\n40\t * Returns false on any error (bad base64, wrong key, etc.).\n41\t */\n42\texport async function verifySessionToken(token: string, adminPassword: string): Promise<boolean> {\n43\t\ttry {\n44\t\t\tconst sig = Uint8Array.from(atob(token), (c) => c.charCodeAt(0));\n45\t\t\tconst key = await importHmacKey(adminPassword);\n46\t\t\treturn await crypto.subtle.verify('HMAC', key, sig, SESSION_CLAIM);\n47\t\t} catch {\n48\t\t\treturn false;\n49\t\t}\n50\t}\n51\t"}]},"parent_tool_use_id":null,"session_id":"abc65d49-6ed9-4bce-bf7d-0cbc7d4963cb","uuid":"65efb7d4-168d-4f1e-bcc2-75d837a7426e","timestamp":"2026-05-26T17:40:11.426Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/lib/server/session.ts","content":"export const COOKIE_NAME = 'admin_session';\n\n// Fixed claim data signed by the ADMIN_PASSWORD key.\nconst SESSION_CLAIM = new TextEncoder().encode('admin:v1');\n\nfunction timingSafeEqualBytes(a: Uint8Array, b: Uint8Array): boolean {\n\tconst maxLen = Math.max(a.length, b.length);\n\tlet diff = a.length ^ b.length;\n\tfor (let i = 0; i < maxLen; i++) {\n\t\tdiff |= (a[i] ?? 0) ^ (b[i] ?? 0);\n\t}\n\treturn diff === 0;\n}\n\n/** Constant-time string comparison (UTF-8 byte level). */\nexport function timingSafeEqual(a: string, b: string): boolean {\n\tconst enc = new TextEncoder();\n\treturn timingSafeEqualBytes(enc.encode(a), enc.encode(b));\n}\n\nasync function importHmacKey(password: string): Promise<CryptoKey> {\n\treturn crypto.subtle.importKey(\n\t\t'raw',\n\t\tnew TextEncoder().encode(password),\n\t\t{ name: 'HMAC', hash: 'SHA-256' },\n\t\tfalse,\n\t\t['sign', 'verify']\n\t);\n}\n\n/** Create a signed session token bound to the given admin password. */\nexport async function createSessionToken(adminPassword: string): Promise<string> {\n\tconst key = await importHmacKey(adminPassword);\n\tconst sig = await crypto.subtle.sign('HMAC', key, SESSION_CLAIM);\n\treturn btoa(String.fromCharCode(...new Uint8Array(sig)));\n}\n\n/**\n * Verify a session token using constant-time HMAC comparison.\n * Returns false on any error (bad base64, wrong key, etc.).\n */\nexport async function verifySessionToken(token: string, adminPassword: string): Promise<boolean> {\n\ttry {\n\t\tconst sig = Uint8Array.from(atob(token), (c) => c.charCodeAt(0));\n\t\tconst key = await importHmacKey(adminPassword);\n\t\treturn await crypto.subtle.verify('HMAC', key, sig, SESSION_CLAIM);\n\t} catch {\n\t\treturn false;\n\t}\n}\n","numLines":51,"startLine":1,"totalLines":51}}}
