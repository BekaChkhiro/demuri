et')).toBe(false);\n\t});\n\n\tit('produces the same token for the same password (deterministic HMAC)', async () => {\n\t\tconst t1 = await createSessionToken('mypassword');\n\t\tconst t2 = await createSessionToken('mypassword');\n\t\texpect(t1).toBe(t2);\n\t});\n\n\tit('produces different tokens for different passwords', async () => {\n\t\tconst t1 = await createSessionToken('pass1');\n\t\tconst t2 = await createSessionToken('pass2');\n\t\texpect(t1).not.toBe(t2);\n\t});\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":11490,"cache_read_input_tokens":46323,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":11490},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"abc65d49-6ed9-4bce-bf7d-0cbc7d4963cb","uuid":"fb136599-04dd-4afd-9521-879a2b527ce4","request_id":"req_011CbRbQiTYSTmQVBjhHxRMc"}
