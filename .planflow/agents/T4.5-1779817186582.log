116\t\n117\t/** Fetch a single photo row by id. Returns null when not found. */\n118\texport async function getPhotoById(db: D1Database, id: string): Promise<Photo | null> {\n119\t\treturn db.prepare('SELECT * FROM photos WHERE id = ?').bind(id).first<Photo>() ?? null;\n120\t}\n121\t\n122\t/**\n123\t * Set the hidden flag for a photo. Returns true when the row was updated,\n124\t * false when no row matched (not found).\n125\t */\n126\texport async function setPhotoHidden(\n127\t\tdb: D1Database,\n128\t\tid: string,\n129\t\thidden: boolean\n130\t): Promise<boolean> {\n131\t\tconst result = await db\n132\t\t\t.prepare('UPDATE photos SET hidden = ? WHERE id = ?')\n133\t\t\t.bind(hidden ? 1 : 0, id)\n134\t\t\t.run();\n135\t\treturn (result.meta.changes ?? 0) > 0;\n136\t}\n137\t\n138\t/**\n139\t * Delete a photo row from D1. Returns true when a row was deleted,\n140\t * false when no row matched (not found).\n141\t */\n142\texport async function deletePhotoRow(db: D1Database, id: string): Promise<boolean> {\n143\t\tconst result = await db.prepare('DELETE FROM photos WHERE id = ?').bind(id).run();\n144\t\treturn (result.meta.changes ?? 0) > 0;\n145\t}\n146\t"}]},"parent_tool_use_id":null,"session_id":"abc65d49-6ed9-4bce-bf7d-0cbc7d4963cb","uuid":"9376b587-cc6d-462d-91d8-1daf4382b3e4","timestamp":"2026-05-26T17:40:17.950Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/beqolozi/Desktop/demuri/src/lib/server/photos.ts","content":"import type { D1Database } from '@cloudflare/workers-types';\nimport type { Photo } from './db';\n\nexport const MAX_LIMIT = 60;\nexport const DEFAULT_LIMIT = 20;\n\n/** Fields needed to persist a freshly uploaded photo. */\nexport interface NewPhoto {\n\tid: string;\n\tr2_key: string;\n\tname: string | null;\n\tcreated_at: number;\n}\n\n/** Max length we store for a client-supplied display name. */\nexport const MAX_NAME_LENGTH = 80;\n\n/**\n * Normalize a client-supplied name: strip control characters, trim, and cap\n * the length. 