{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012vAQqtXKXi2CEo9dcWok7C","type":"tool_result","content":"1\timport type { D1Database } from '@cloudflare/workers-types';\n2\timport type { Photo } from './db';\n3\t\n4\texport const MAX_LIMIT = 60;\n5\texport const DEFAULT_LIMIT = 20;\n6\t\n7\t/** Fields needed to persist a freshly uploaded photo. */\n8\texport interface NewPhoto {\n9\t\tid: string;\n10\t\tr2_key: string;\n11\t\tname: string | null;\n12\t\tcreated_at: number;\n13\t}\n14\t\n15\t/** Max length we store for a client-supplied display name. */\n16\texport const MAX_NAME_LENGTH = 80;\n17\t\n18\t/**\n19\t * Normalize a client-supplied name: strip control characters, trim, and cap\n20\t * the length. Returns null for missing or effectively empty names — we never\n21\t * trust the raw value.\n22\t */\n23\texport function sanitizeName(raw: FormDataEntryValue | null): string | null {\n24\t\tif (typeof raw !== 'string') {\n25\t\t\treturn null;\n26\t\t}\n27\t\t// Drop ASCII control characters (incl. newlines/tabs and DEL) before trimming.\n28\t\tconst cleaned = Array.from(raw)\n29\t\t\t.filter((ch) => {\n30\t\t\t\tconst code = ch.charCodeAt(0);\n31\t\t\t\treturn code >= 0x20 && code !== 0x7f;\n32\t\t\t})\n33\t\t\t.join('')\n34\t\t\t.trim();\n35\t\tif (cleaned.length === 0) {\n36\t\t\treturn null;\n37\t\t}\n38\t\treturn cleaned.slice(0, MAX_NAME_LENGTH);\n39\t}\n40\t\n41\t/** Build the public URL for a stored R2 object. */\n42\texport function publicUrl(base: string, r2_key: string): string {\n43\t\treturn `${base.replace(/\\/+$/, '')}/${r2_key}`;\n44\t}\n45\t\n46\t/** Insert a new photo metadata row. Rows default to visible (hidden = 0). */\n47\texport async function insertPhoto(db: D1Database, photo: NewPhoto): Promise<void> {\n48\t\tawait db\n49\t\t\t.prepare('INSERT INTO photos (id, r2_key, name, created_at, hidden) VALUES (?, ?, ?, ?, 0)')\n50\t\t\t.bind(photo.id, photo.r2_key, photo.name, photo.created_at)\n51\t\t\t.run();\n52\t}\n53\